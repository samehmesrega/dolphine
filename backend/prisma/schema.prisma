// =============================================================
// Dolphin Platform - Unified Prisma Schema
// Single schema, single client, table prefixes for logical grouping
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// AUTH: المستخدمون والأدوار والموديولات
// =============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  phone         String?
  isActive      Boolean   @default(true) @map("is_active")
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  status        String    @default("active") // "pending", "active", "suspended"
  authMethod    String    @default("email") @map("auth_method") // "email", "google"
  emailVerified Boolean   @default(true) @map("email_verified")
  googleId      String?   @unique @map("google_id")
  avatarUrl     String?   @map("avatar_url")
  verificationToken String? @map("verification_token")
  resetToken        String? @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  roleId        String    @map("role_id")
  role          Role      @relation(fields: [roleId], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  whatsappNumber String?  @map("whatsapp_number")

  // Relations - Leads module
  assignedLeads      Lead[]            @relation("AssignedLeads")
  communications     Communication[]
  responseRequests   ResponseRequest[] @relation("RequestedFrom")
  callbacksRequested ResponseRequest[] @relation("RequestedBy")
  tasks              Task[]            @relation("AssignedTasks")

  // Relations - Auth
  userPermissions    UserPermission[]
  auditLogs          AuditLog[]
  shiftMembers       ShiftMember[]
  notifications      Notification[]
  moduleAccess       ModuleAccess[]

  // Relations - Marketing module
  createdCreatives      Creative[]          @relation("CreativeCreator")
  requestedCreatives    CreativeRequest[]   @relation("RequestRequester")
  assignedRequests      CreativeRequest[]   @relation("RequestAssignee")
  submittedIdeas        Idea[]              @relation("IdeaSubmitter")
  ideaComments          IdeaComment[]       @relation("IdeaCommenter")
  competitorReferences  CompetitorReference[] @relation("CompetitorAdder")
  assignedScripts       Script[]            @relation("ScriptAssignee")
  createdPosts          ScheduledPost[]     @relation("PostCreator")
  createdLandingPages   LandingPage[]       @relation("LandingPageCreator")
  blacklistedPhones     BlacklistedPhone[]  @relation("BlacklistCreator")

  // Relations - Tickets module
  tickets               Ticket[]            @relation("TicketCreator")
  ticketComments        TicketComment[]     @relation("TicketCommenter")

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  module          String
  description     String?
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  grant        Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

// --- Platform Modules ---

model Module {
  id          String         @id @default(uuid())
  name        String         // "Dolphin Leads", "Dolphin Marketing"
  slug        String         @unique // "leads", "marketing"
  icon        String?        // emoji or icon name
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  order       Int            @default(0)
  roles       ModuleRole[]
  access      ModuleAccess[]

  @@map("platform_modules")
}

model ModuleRole {
  id          String         @id @default(uuid())
  moduleId    String         @map("module_id")
  module      Module         @relation(fields: [moduleId], references: [id])
  name        String         // "Sales Manager"
  slug        String         // "sales_manager"
  permissions Json           // ["leads.view", "leads.create", ...]
  isDefault   Boolean        @default(false) @map("is_default")
  access      ModuleAccess[]

  @@unique([moduleId, slug])
  @@map("platform_module_roles")
}

model ModuleAccess {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String     @map("module_id")
  module       Module     @relation(fields: [moduleId], references: [id])
  moduleRoleId String     @map("module_role_id")
  moduleRole   ModuleRole @relation(fields: [moduleRoleId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, moduleId])
  @@map("platform_module_access")
}

// =============================================================
// LEADS: الليدز والعملاء والطلبات
// =============================================================

model Customer {
  id           String   @id @default(uuid())
  number       Int      @default(autoincrement()) @unique
  name         String
  phone        String   @unique
  whatsapp     String?
  email        String?
  address      String?
  customFields Json?    @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  leads  Lead[]
  orders Order[]

  @@map("customers")
}

model Lead {
  id                  String     @id @default(uuid())
  number              Int        @default(autoincrement()) @unique
  name                String
  phone               String
  phoneNormalized     String     @map("phone_normalized")
  whatsapp            String?
  email               String?
  address             String?
  customFields        Json?      @map("custom_fields")
  source              String
  sourceDetail        String?    @map("source_detail")
  statusId            String     @map("status_id")
  status              LeadStatus @relation(fields: [statusId], references: [id])
  assignedToId        String?    @map("assigned_to_id")
  assignedTo          User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  customerId          String?    @map("customer_id")
  customer            Customer?  @relation(fields: [customerId], references: [id])
  lastStatusChangedAt DateTime?  @map("last_status_changed_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  // Marketing integration fields (Phase 9)
  campaignId    String? @map("campaign_id")
  creativeCode  String? @map("creative_code")
  landingPageId String? @map("landing_page_id")
  utmSource     String? @map("utm_source")
  utmMedium     String? @map("utm_medium")
  utmCampaign   String? @map("utm_campaign")
  utmContent    String? @map("utm_content")

  communications   Communication[]
  responseRequests ResponseRequest[]
  orders           Order[]
  productInterests ProductInterest[]
  tasks            Task[]

  @@index([phoneNormalized])
  @@index([statusId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([creativeCode])
  @@map("leads")
}

model LeadStatus {
  id       String   @id @default(uuid())
  name     String
  slug     String   @unique
  color    String?
  orderNum Int      @default(0) @map("order_num")
  isActive Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@map("lead_statuses")
}

model ProductInterest {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  productId    String?  @map("product_id")
  product      Product? @relation(fields: [productId], references: [id])
  variation    Json?
  customFields Json?    @map("custom_fields")
  quantity     Int      @default(1)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@index([productId])
  @@map("product_interests")
}

model Communication {
  id        String    @id @default(uuid())
  leadId    String    @map("lead_id")
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  type      String
  notes     String?
  statusId  String?   @map("status_id")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([leadId])
  @@index([createdAt])
  @@map("communications")
}

model ResponseRequest {
  id              String    @id @default(uuid())
  leadId          String    @map("lead_id")
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  requestedFromId String    @map("requested_from_id")
  requestedFrom   User      @relation("RequestedFrom", fields: [requestedFromId], references: [id])
  communicationId String?   @map("communication_id")
  requestedById   String?   @map("requested_by_id")
  requestedBy     User?     @relation("RequestedBy", fields: [requestedById], references: [id])
  note            String?
  response        String?
  respondedAt     DateTime? @map("responded_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([requestedFromId])
  @@map("response_requests")
}

model LeadSource {
  id           String   @id @default(uuid())
  name         String
  type         String
  config       Json
  fieldMapping Json?    @map("field_mapping")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("lead_sources")
}

model Shift {
  id                String   @id @default(uuid())
  name              String
  startTime         String   @map("start_time")
  endTime           String   @map("end_time")
  daysOfWeek        Json     @map("days_of_week")
  roundRobin        Boolean  @default(false) @map("round_robin")
  isActive          Boolean  @default(true) @map("is_active")
  lastAssignedIndex Int      @default(-1) @map("last_assigned_index")
  lastAssignedDate  String?  @map("last_assigned_date") // YYYY-MM-DD — reset يومي
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  shiftMembers ShiftMember[]

  @@map("shifts")
}

model ShiftMember {
  id        String   @id @default(uuid())
  shiftId   String   @map("shift_id")
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int      @default(0) @map("day_of_week")
  orderNum  Int      @default(0) @map("order_num")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([shiftId, userId, dayOfWeek])
  @@map("shift_members")
}

model Product {
  id            String   @id @default(uuid())
  wooCommerceId Int      @unique @map("woo_commerce_id")
  name          String
  slug          String?
  data          Json
  variations    Json?
  isActive      Boolean  @default(true) @map("is_active")
  syncedAt      DateTime @default(now()) @map("synced_at")

  productInterests ProductInterest[]
  orderItems       OrderItem[]
  formConnections  FormConnection[]
  sheetConnections SheetConnection[]
  kbProducts       KbProduct[]

  @@map("products")
}

model Order {
  id                  String    @id @default(uuid())
  number              Int       @default(autoincrement()) @unique
  leadId              String    @map("lead_id")
  lead                Lead      @relation(fields: [leadId], references: [id])
  customerId          String    @map("customer_id")
  customer            Customer  @relation(fields: [customerId], references: [id])
  wooCommerceId       Int?      @unique @map("woo_commerce_id")
  status              String
  paymentType         String    @map("payment_type")
  transferImage       String?   @map("transfer_image")
  shippingName        String    @map("shipping_name")
  shippingPhone       String    @map("shipping_phone")
  shippingGovernorate String?   @map("shipping_governorate")
  shippingCity        String?   @map("shipping_city")
  shippingAddress     String?   @map("shipping_address")
  notes               String?
  accountsConfirmed   Boolean   @default(false) @map("accounts_confirmed")
  accountsConfirmedAt DateTime? @map("accounts_confirmed_at")
  accountsConfirmedBy String?   @map("accounts_confirmed_by")
  rejectedReason      String?   @map("rejected_reason")
  discount            Decimal?  @default(0) @map("discount") @db.Decimal(12, 2)
  discountReason      String?   @map("discount_reason")
  partialAmount       Decimal?  @default(0) @map("partial_amount") @db.Decimal(12, 2)
  bostaDeliveryId     String?   @unique @map("bosta_delivery_id")
  trackingNumber      String?   @map("tracking_number")
  bostaStatus         String?   @map("bosta_status")
  bostaError          String?   @map("bosta_error")

  // حقول طبقات الحماية
  accountsStatus       String    @default("pending") @map("accounts_status") // pending, confirmed, rejected
  trustScore           Int?      @map("trust_score")
  senderPhone          String?   @map("sender_phone")
  imageHash            String?   @map("image_hash")
  transactionRef       String?   @map("transaction_ref")
  noTransferImage      Boolean   @default(false) @map("no_transfer_image")
  noImageReason        String?   @map("no_image_reason")
  transferVerification Json?     @map("transfer_verification")

  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  orderItems OrderItem[]
  tasks      Task[]

  @@index([status])
  @@index([accountsStatus])
  @@index([leadId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  productName String?  @map("product_name")
  variation   Json?
  quantity    Int      @default(1)
  price       Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("order_items")
}

model IntegrationSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("integration_settings")
}

model BlacklistedPhone {
  id        String   @id @default(uuid())
  phone     String   @unique
  reason    String?
  addedBy   String   @map("added_by")
  creator   User     @relation("BlacklistCreator", fields: [addedBy], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blacklisted_phones")
}

model SheetConnection {
  id            String   @id @default(uuid())
  name          String
  spreadsheetId String   @map("spreadsheet_id")
  sheetName     String   @default("Sheet1") @map("sheet_name")
  token         String   @unique
  fieldMapping  Json?    @map("field_mapping")
  productId     String?  @map("product_id")
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lastSyncedRow Int      @default(0) @map("last_synced_row")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("sheet_connections")
}

model FormConnection {
  id           String   @id @default(uuid())
  name         String
  shortcode    String?  @map("shortcode")
  token        String   @unique
  fieldMapping Json?    @map("field_mapping")
  productId    String?  @map("product_id")
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("form_connections")
}

model CustomFieldConfig {
  id       String   @id @default(uuid())
  entity   String
  name     String
  slug     String
  orderNum Int      @default(0) @map("order_num")
  isActive Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entity, slug])
  @@map("custom_field_configs")
}

// =============================================================
// PLATFORM: التدقيق والإشعارات والتاسكات
// =============================================================

model AuditLog {
  id       String   @id @default(uuid())
  userId   String?  @map("user_id")
  user     User?    @relation(fields: [userId], references: [id])
  action   String
  entity   String
  entityId String   @map("entity_id")
  oldData  Json?    @map("old_data")
  newData  Json?    @map("new_data")
  ip       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id       String    @id @default(uuid())
  userId   String    @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  body     String?
  type     String
  entity   String?
  entityId String?   @map("entity_id")
  link     String?
  isRead   Boolean   @default(false) @map("is_read")
  readAt   DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Task {
  id           String    @id @default(uuid())
  type         String
  title        String
  description  String?
  status       String    @default("pending")
  assignedToId String    @map("assigned_to_id")
  assignedTo   User      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  leadId       String?   @map("lead_id")
  lead         Lead?     @relation(fields: [leadId], references: [id])
  orderId      String?   @map("order_id")
  order        Order?    @relation(fields: [orderId], references: [id])
  ruleId       String?   @map("rule_id")
  rule         TaskRule? @relation(fields: [ruleId], references: [id])
  snoozedUntil DateTime? @map("snoozed_until")
  completedAt  DateTime? @map("completed_at")
  completedById String?  @map("completed_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([assignedToId])
  @@index([status])
  @@index([leadId])
  @@map("tasks")
}

model TaskRule {
  id         String   @id @default(uuid())
  action     String
  statusSlug String   @map("status_slug")
  afterHours Int      @map("after_hours")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@map("task_rules")
}

// =============================================================
// MARKETING: الكرييتيف والتاجز والطلبات والأداء
// =============================================================

model MktProject {
  id        String         @id @default(uuid())
  name      String         @unique // "Print In", "Picked In", "Choroida"
  slug      String         @unique
  language  String         @default("ar") // "ar" | "en"
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  products         MktProduct[]
  creatives        Creative[]
  creativeRequests CreativeRequest[]
  ideas            Idea[]
  scripts          Script[]
  kbProducts       KbProduct[]

  @@map("mkt_projects")
}

model MktProduct {
  id            String     @id @default(uuid())
  name          String     // "Dual Name", "Slipperz"
  projectId     String     @map("project_id")
  project       MktProject @relation(fields: [projectId], references: [id])
  wooCommerceId Int?       @map("woo_commerce_id") // linked from Leads module
  isActive      Boolean    @default(true) @map("is_active")
  createdAt     DateTime   @default(now()) @map("created_at")

  creatives        Creative[]
  creativeRequests CreativeRequest[]

  @@map("mkt_products")
}

enum CreativeType {
  REEL
  VIDEO
  STORY
  IMAGE
  SESSION
}

enum CreativeStatus {
  ACTIVE
  TESTING
  WINNER
  LOSER
  PAUSED
}

model Creative {
  id           String         @id @default(uuid())
  code         String         @unique // auto-generated: "1-2-3-001"
  name         String
  description  String?
  type         CreativeType
  driveUrl     String?        @map("drive_url")
  thumbnailUrl String?        @map("thumbnail_url")
  projectId    String         @map("project_id")
  project      MktProject     @relation(fields: [projectId], references: [id])
  productId    String?        @map("product_id")
  product      MktProduct?    @relation(fields: [productId], references: [id])
  language         String         @default("ar")
  photographerName String?        @map("photographer_name")
  creatorId        String         @map("creator_id")
  creator          User           @relation("CreativeCreator", fields: [creatorId], references: [id])
  status           CreativeStatus @default(ACTIVE)
  requestId    String?        @map("request_id")
  request      CreativeRequest? @relation(fields: [requestId], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tags           CreativeTag[]
  performances   CreativePerformance[]
  scheduledPosts ScheduledPost[]

  @@index([projectId])
  @@index([status])
  @@index([code])
  @@map("mkt_creatives")
}

model CreativeCodeConfig {
  id        String   @id @default(uuid())
  segments  Json     // configurable segments with codes and labels
  separator String   @default("-")
  seqDigits Int      @default(3) @map("seq_digits")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("mkt_creative_code_config")
}

model TagCategory {
  id      String  @id @default(uuid())
  name    String  @unique // "Season", "Content Type", "Platform"
  isFixed Boolean @default(true) @map("is_fixed")

  tags Tag[]

  @@map("mkt_tag_categories")
}

model Tag {
  id         String       @id @default(uuid())
  name       String       // "Ramadan", "UGC", "Meta"
  categoryId String?      @map("category_id")
  category   TagCategory? @relation(fields: [categoryId], references: [id])

  creatives CreativeTag[]

  @@unique([name, categoryId])
  @@map("mkt_tags")
}

model CreativeTag {
  id         String   @id @default(uuid())
  creativeId String   @map("creative_id")
  creative   Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  tagId      String   @map("tag_id")
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([creativeId, tagId])
  @@map("mkt_creative_tags")
}

model SavedFilter {
  id      String @id @default(uuid())
  name    String // "Ramadan Dual Name Videos"
  userId  String @map("user_id")
  filters Json   // { projectId: "x", tags: ["y"], status: "PUBLISHED", type: "VIDEO" }

  @@map("mkt_saved_filters")
}

enum RequestStatus {
  NEW
  IN_PRODUCTION
  DONE
  CANCELLED
}

model CreativeRequest {
  id            String        @id @default(uuid())
  title         String
  projectId     String        @map("project_id")
  project       MktProject    @relation(fields: [projectId], references: [id])
  productId     String?       @map("product_id")
  product       MktProduct?   @relation(fields: [productId], references: [id])
  platform      String        // "meta", "tiktok", "snapchat"
  language      String        @default("ar")
  instructions  String
  referenceUrls Json?         @map("reference_urls")
  deadline      DateTime?
  status        RequestStatus @default(NEW)
  requestedBy   String        @map("requested_by")
  requester     User          @relation("RequestRequester", fields: [requestedBy], references: [id])
  assignedTo    String?       @map("assigned_to")
  assignee      User?         @relation("RequestAssignee", fields: [assignedTo], references: [id])
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  creatives Creative[]

  @@index([status])
  @@map("mkt_creative_requests")
}

model CreativePerformance {
  id          String   @id @default(uuid())
  creativeId  String   @map("creative_id")
  creative    Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)
  date        DateTime
  platform    String   // "meta", "google", "tiktok", "snapchat"
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Float    @default(0)
  leads       Int      @default(0)
  orders      Int      @default(0)
  revenue     Float    @default(0)

  @@unique([creativeId, date, platform])
  @@map("mkt_creative_performance")
}

// --- Ideas & Scripts ---

enum IdeaStatus {
  NEW
  APPROVED
  IN_PRODUCTION
  DONE
  REJECTED
}

model Idea {
  id            String     @id @default(uuid())
  title         String
  description   String
  projectId     String     @map("project_id")
  project       MktProject @relation(fields: [projectId], references: [id])
  platform      String?
  contentType   String?    @map("content_type")
  status        IdeaStatus @default(NEW)
  submittedBy   String     @map("submitted_by")
  submitter     User       @relation("IdeaSubmitter", fields: [submittedBy], references: [id])
  referenceUrls Json?      @map("reference_urls")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  comments IdeaComment[]
  scripts  Script[]

  @@index([status])
  @@map("mkt_ideas")
}

model IdeaComment {
  id        String   @id @default(uuid())
  ideaId    String   @map("idea_id")
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("IdeaCommenter", fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("mkt_idea_comments")
}

model CompetitorReference {
  id             String   @id @default(uuid())
  title          String
  url            String
  screenshotUrl  String?  @map("screenshot_url")
  competitorName String?  @map("competitor_name")
  platform       String
  notes          String?
  tags           Json?
  addedBy        String   @map("added_by")
  adder          User     @relation("CompetitorAdder", fields: [addedBy], references: [id])
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("mkt_competitor_references")
}

enum ScriptStatus {
  DRAFT
  APPROVED
  IN_PRODUCTION
  DONE
}

model Script {
  id         String       @id @default(uuid())
  ideaId     String?      @map("idea_id")
  idea       Idea?        @relation(fields: [ideaId], references: [id])
  title      String
  projectId  String       @map("project_id")
  project    MktProject   @relation(fields: [projectId], references: [id])
  platform   String
  audience   String?
  language   String       @default("ar")
  status     ScriptStatus @default(DRAFT)
  assignedTo String?      @map("assigned_to")
  assignee   User?        @relation("ScriptAssignee", fields: [assignedTo], references: [id])
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  scenes   ScriptScene[]
  versions ScriptVersion[]

  @@map("mkt_scripts")
}

model ScriptScene {
  id          String  @id @default(uuid())
  scriptId    String  @map("script_id")
  script      Script  @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  order       Int
  description String
  cameraAngle String? @map("camera_angle")
  setting     String?
  textOverlay String? @map("text_overlay")
  voiceover   String?
  durationSec Int?    @map("duration_sec")

  @@map("mkt_script_scenes")
}

model ScriptVersion {
  id        String   @id @default(uuid())
  scriptId  String   @map("script_id")
  script    Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  version   Int
  content   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("mkt_script_versions")
}

// --- Publishing & Social Pages ---

model Brand {
  id        String       @id @default(uuid())
  name      String       @unique // "Print In", "Picked In", "Choroida"
  slug      String       @unique
  language  String       @default("ar") // "ar" | "en"
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  pages        SocialPage[]
  adAccounts   AdAccount[]
  landingPages LandingPage[]

  @@map("mkt_brands")
}

model SocialPage {
  id           String    @id @default(uuid())
  platform     String    // "facebook", "instagram", "tiktok"
  pageId       String    @map("page_id") // platform's page/account ID
  pageName     String    @map("page_name")
  accessToken  String    @map("access_token") // encrypted with AES-256-GCM
  refreshToken String?   @map("refresh_token") // encrypted with AES-256-GCM
  tokenExpiry  DateTime? @map("token_expiry")
  brandId      String    @map("brand_id")
  brand        Brand     @relation(fields: [brandId], references: [id])
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  postPages ScheduledPostPage[]

  @@unique([platform, pageId])
  @@map("mkt_social_pages")
}

enum PostType {
  POST
  STORY
  REEL
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

model ScheduledPost {
  id           String     @id @default(uuid())
  creativeId   String?    @map("creative_id") // linked creative from library
  creative     Creative?  @relation(fields: [creativeId], references: [id])
  caption      String     // post text/description
  mediaUrl     String?    @map("media_url") // Google Drive URL or direct URL
  postType     PostType   @default(POST) @map("post_type")
  scheduledAt  DateTime   @map("scheduled_at")
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime?  @map("published_at")
  publishedIds Json?      @map("published_ids") // { facebook: "post_123", instagram: "media_456" }
  error        String?
  createdBy    String     @map("created_by")
  creator      User       @relation("PostCreator", fields: [createdBy], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  pages ScheduledPostPage[]

  @@index([scheduledAt])
  @@index([status])
  @@map("mkt_scheduled_posts")
}

model ScheduledPostPage {
  id              String        @id @default(uuid())
  scheduledPostId String        @map("scheduled_post_id")
  scheduledPost   ScheduledPost @relation(fields: [scheduledPostId], references: [id], onDelete: Cascade)
  socialPageId    String        @map("social_page_id")
  socialPage      SocialPage    @relation(fields: [socialPageId], references: [id])
  publishedId     String?       @map("published_id") // platform's post ID after publishing
  status          PostStatus    @default(DRAFT)
  error           String?
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([scheduledPostId, socialPageId])
  @@map("mkt_scheduled_post_pages")
}

// =============================================================
// MARKETING: Media Buying — حسابات الإعلانات والحملات والأداء
// =============================================================

model AdAccount {
  id           String    @id @default(uuid())
  platform     String    // "meta", "google", "tiktok", "snapchat"
  accountId    String    @map("account_id") // platform's account ID
  accountName  String    @map("account_name")
  accessToken  String    @map("access_token") // encrypted with AES-256-GCM
  refreshToken String?   @map("refresh_token") // encrypted with AES-256-GCM
  tokenExpiry  DateTime? @map("token_expiry")
  brandId      String    @map("brand_id")
  brand        Brand     @relation(fields: [brandId], references: [id])
  isActive     Boolean   @default(true) @map("is_active")
  lastSyncAt   DateTime? @map("last_sync_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  campaigns Campaign[]
  syncLogs  SyncLog[]

  @@unique([platform, accountId])
  @@map("mkt_ad_accounts")
}

model Campaign {
  id          String     @id @default(uuid())
  adAccountId String     @map("ad_account_id")
  adAccount   AdAccount  @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  platformId  String     @map("platform_id") // campaign ID on the platform
  name        String
  status      String     // ACTIVE, PAUSED, COMPLETED
  objective   String?    // CONVERSIONS, TRAFFIC, etc.
  budget      Float?
  startDate   DateTime?  @map("start_date")
  endDate     DateTime?  @map("end_date")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  adSets  AdSet[]
  metrics AdMetric[]

  @@unique([adAccountId, platformId])
  @@map("mkt_campaigns")
}

model AdSet {
  id         String   @id @default(uuid())
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  platformId String   @map("platform_id")
  name       String
  status     String
  targeting  Json?    // audience targeting details
  budget     Float?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ads     Ad[]
  metrics AdMetric[]

  @@unique([campaignId, platformId])
  @@map("mkt_ad_sets")
}

model Ad {
  id           String @id @default(uuid())
  adSetId      String @map("ad_set_id")
  adSet        AdSet  @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  platformId   String @map("platform_id")
  name         String // should contain creative code for UTM tracking
  status       String
  creativeCode String? @map("creative_code") // extracted from ad name (e.g., "1-2-3-001")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  metrics AdMetric[]

  @@unique([adSetId, platformId])
  @@map("mkt_ads")
}

model AdMetric {
  id          String    @id @default(uuid())
  date        DateTime
  adAccountId String?   @map("ad_account_id")
  campaignId  String?   @map("campaign_id")
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adSetId     String?   @map("ad_set_id")
  adSet       AdSet?    @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  adId        String?   @map("ad_id")
  ad          Ad?       @relation(fields: [adId], references: [id], onDelete: Cascade)
  impressions     Int       @default(0)
  reach           Int       @default(0)
  clicks          Int       @default(0)
  outboundClicks  Int       @default(0) @map("outbound_clicks")
  spend           Float     @default(0)
  conversions     Int       @default(0)
  leads           Int       @default(0)      // Meta "lead" actions
  purchases       Int       @default(0)      // Meta "purchase" = Digitics "lead" (COD form submit)
  revenue         Float     @default(0)
  frequency       Float?                     // impressions / reach
  cpm             Float?                     // cost per 1000 impressions
  ctr             Float?                     // clicks / impressions
  outboundCtr     Float?    @map("outbound_ctr") // outbound_clicks / impressions
  cpc             Float?                     // spend / clicks
  cpl             Float?                     // spend / purchases (Digitics "lead" = Meta purchase)
  cpa             Float?                     // spend / confirmed orders (from Dolphin Leads)
  roas            Float?                     // revenue / spend

  @@unique([date, adId])
  @@index([date])
  @@index([campaignId])
  @@map("mkt_ad_metrics")
}

model SyncLog {
  id             String    @id @default(uuid())
  adAccountId    String    @map("ad_account_id")
  adAccount      AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  syncType       String    @map("sync_type") // "incremental" | "full"
  status         String    // "success" | "failed" | "in_progress"
  recordsUpdated Int       @default(0) @map("records_updated")
  error          String?
  duration       Int?      // milliseconds
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")

  @@map("mkt_sync_logs")
}

// =============================================================
// MARKETING: Landing Pages — صفحات الهبوط وبيلدر الـ AI
// =============================================================

enum LandingPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ABTestStatus {
  RUNNING
  COMPLETED
  CANCELLED
}

model LandingPage {
  id          String            @id @default(uuid())
  title       String
  slug        String            @unique
  brandId     String            @map("brand_id")
  brand       Brand             @relation(fields: [brandId], references: [id])
  productId   String?           @map("product_id") // optional link to MktProduct
  html        String            // current published HTML
  css         String?           // optional separate CSS
  status      LandingPageStatus @default(DRAFT)
  createdBy   String            @map("created_by")
  creator     User              @relation("LandingPageCreator", fields: [createdBy], references: [id])
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  formTemplateId String?            @map("form_template_id")
  formTemplate   OrderFormTemplate? @relation(fields: [formTemplateId], references: [id])

  versions      LandingPageVersion[]
  fieldMappings FormFieldMapping[]
  abTestsA      ABTest[]             @relation("ABTestPageA")
  abTestsB      ABTest[]             @relation("ABTestPageB")

  @@index([brandId])
  @@index([status])
  @@map("mkt_landing_pages")
}

model LandingPageVersion {
  id            String      @id @default(uuid())
  landingPageId String      @map("landing_page_id")
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  versionNumber Int         @map("version_number")
  html          String
  css           String?
  editPrompt    String?     @map("edit_prompt") // AI prompt that generated this version
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([landingPageId, versionNumber])
  @@map("mkt_landing_page_versions")
}

model FormFieldMapping {
  id            String      @id @default(uuid())
  landingPageId String      @map("landing_page_id")
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  formFieldName String      @map("form_field_name") // field name in the HTML form
  leadField     String      @map("lead_field")       // mapped Lead model field (name, phone, email, etc.)

  @@unique([landingPageId, formFieldName])
  @@map("mkt_form_field_mappings")
}

model ABTest {
  id             String       @id @default(uuid())
  landingPageAId String       @map("landing_page_a_id")
  landingPageA   LandingPage  @relation("ABTestPageA", fields: [landingPageAId], references: [id])
  landingPageBId String       @map("landing_page_b_id")
  landingPageB   LandingPage  @relation("ABTestPageB", fields: [landingPageBId], references: [id])
  trafficSplit   Int          @default(50) @map("traffic_split") // percentage for page A
  status         ABTestStatus @default(RUNNING)
  winnerId       String?      @map("winner_id")
  visitsA        Int          @default(0) @map("visits_a")
  visitsB        Int          @default(0) @map("visits_b")
  conversionsA   Int          @default(0) @map("conversions_a")
  conversionsB   Int          @default(0) @map("conversions_b")
  startedAt      DateTime     @default(now()) @map("started_at")
  completedAt    DateTime?    @map("completed_at")

  @@map("mkt_ab_tests")
}

// =============================================================
// AI PROVIDERS + ORDER FORM TEMPLATES
// =============================================================

model AiProvider {
  id        String   @id @default(uuid())
  provider  String   @unique // "anthropic" | "openai" | "google"
  name      String           // "Anthropic" | "OpenAI" | "Google AI"
  apiKey    String   @map("api_key") // ENCRYPTED with token-encryption.ts
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_providers")
}

model OrderFormTemplate {
  id             String           @id @default(uuid())
  name           String
  slug           String           @unique
  paymentMethods Json             @default("[\"cod\"]") @map("payment_methods")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  fields       OrderFormField[]
  landingPages LandingPage[]

  @@map("mkt_order_form_templates")
}

model OrderFormField {
  id         String            @id @default(uuid())
  templateId String            @map("template_id")
  template   OrderFormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fieldName  String            @map("field_name")
  label      String
  type       String            @default("text") // text|email|tel|select|textarea|number
  required   Boolean           @default(false)
  options    String?           // comma-separated for select type
  leadField  String            @map("lead_field") // name|phone|email|address|whatsapp|custom
  orderNum   Int               @default(0) @map("order_num")

  @@index([templateId])
  @@map("mkt_order_form_fields")
}

// =============================================================
// KNOWLEDGE BASE: بنك المعلومات — بيانات المنتجات الشاملة
// =============================================================

enum KbMediaSource {
  DRIVE
  UPLOAD
}

enum KbPriceType {
  RETAIL
  WHOLESALE
  OFFER
}

enum KbCurrency {
  EGP
  USD
  SAR
  AED
  KWD
}

enum KbUpsellType {
  UPSELL
  CROSSSELL
}

enum KbVariationSource {
  WOOCOMMERCE
  MANUAL
}

model KbProduct {
  id             String    @id @default(uuid())
  name           String
  slug           String    @unique
  sku            String?
  description    String?
  category       String?
  projectId      String?   @map("project_id")
  project        MktProject? @relation(fields: [projectId], references: [id])
  wooProductId   String?   @map("woo_product_id")
  wooProduct     Product?  @relation(fields: [wooProductId], references: [id])
  dimensions     String?
  weight         String?
  driveFolderUrl String?   @map("drive_folder_url")
  isActive       Boolean   @default(true) @map("is_active")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  media          KbMedia[]
  suppliers      KbSupplier[]
  manufacturing  KbManufacturing?
  pricing        KbPricing[]
  variations     KbVariation[]
  marketing      KbMarketing?
  faqs           KbFaq[]
  objections     KbObjection[]
  upsellsFrom    KbUpsell[]  @relation("KbUpsellFrom")
  upsellsTo      KbUpsell[]  @relation("KbUpsellTo")
  afterSales     KbAfterSales?
  salesScripts   KbSalesScript[]

  @@index([category])
  @@index([projectId])
  @@map("kb_products")
}

model KbMedia {
  id         String        @id @default(uuid())
  productId  String        @map("product_id")
  product    KbProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  type       String        // "image" | "video"
  url        String
  thumbnail  String?
  caption    String?
  tags       String?
  source     KbMediaSource @default(UPLOAD)
  orderNum   Int           @default(0) @map("order_num")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([productId])
  @@map("kb_media")
}

model KbSupplier {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  product     KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  contactInfo String?  @map("contact_info")
  rating      Int?     // 1-5
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("kb_suppliers")
}

model KbManufacturing {
  id                  String   @id @default(uuid())
  productId           String   @unique @map("product_id")
  product             KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  materials           String?
  productionSteps     String?  @map("production_steps")
  wastePercentage     Float?   @map("waste_percentage")
  unitCost            Float?   @map("unit_cost")
  unitCostCurrency    String?  @map("unit_cost_currency")
  packagingType       String?  @map("packaging_type")
  packagingDimensions String?  @map("packaging_dimensions")
  packagingCost       Float?   @map("packaging_cost")
  shippingTerms       String?  @map("shipping_terms")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("kb_manufacturing")
}

model KbPricing {
  id          String      @id @default(uuid())
  productId   String      @map("product_id")
  product     KbProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationId String?     @map("variation_id")
  variation   KbVariation? @relation(fields: [variationId], references: [id], onDelete: Cascade)
  currency    KbCurrency
  priceType   KbPriceType @map("price_type")
  price       Decimal  @db.Decimal(12, 2)
  notes       String?
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([productId])
  @@map("kb_pricing")
}

model KbVariation {
  id              String            @id @default(uuid())
  productId       String            @map("product_id")
  product         KbProduct         @relation(fields: [productId], references: [id], onDelete: Cascade)
  name            String
  color           String?
  size            String?
  sku             String?
  wooVariationId  Int?              @map("woo_variation_id")
  source          KbVariationSource @default(MANUAL)
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")

  pricing KbPricing[]

  @@index([productId])
  @@map("kb_variations")
}

model KbMarketing {
  id                    String   @id @default(uuid())
  productId             String   @unique @map("product_id")
  product               KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  usps                  String?
  targetAudience        String?  @map("target_audience")
  competitorComparison  String?  @map("competitor_comparison")
  brandVoice            String?  @map("brand_voice")
  keywords              String?
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("kb_marketing")
}

model KbFaq {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  product    KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  question   String
  answer     String
  orderNum   Int      @default(0) @map("order_num")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("kb_faqs")
}

model KbObjection {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  product    KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  objection  String
  response   String
  orderNum   Int      @default(0) @map("order_num")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@map("kb_objections")
}

model KbUpsell {
  id               String      @id @default(uuid())
  productId        String      @map("product_id")
  product          KbProduct   @relation("KbUpsellFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProductId String      @map("related_product_id")
  relatedProduct   KbProduct   @relation("KbUpsellTo", fields: [relatedProductId], references: [id], onDelete: Cascade)
  type             KbUpsellType
  notes            String?
  orderNum         Int          @default(0) @map("order_num")

  @@index([productId])
  @@map("kb_upsells")
}

model KbAfterSales {
  id                  String   @id @default(uuid())
  productId           String   @unique @map("product_id")
  product             KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  returnPolicy        String?  @map("return_policy")
  usageInstructions   String?  @map("usage_instructions")
  troubleshooting     String?
  spareParts          String?  @map("spare_parts")
  warrantyTerms       String?  @map("warranty_terms")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("kb_after_sales")
}

model KbSalesScript {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  product    KbProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  title      String
  content    String
  orderNum   Int      @default(0) @map("order_num")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@map("kb_sales_scripts")
}

// =============================================================
// TICKETS: التذاكر والبلاغات
// =============================================================

model Ticket {
  id          String    @id @default(uuid())
  type        String    // bug, improvement, suggestion
  description String
  screenshot  String?   @db.Text // base64 screenshot
  pageUrl     String?   @map("page_url")
  userAgent   String?   @map("user_agent")
  status      String    @default("new") // new, reviewing, in_progress, resolved, closed
  priority    String?   // critical, high, medium, low
  createdBy   String    @map("created_by")
  creator     User      @relation("TicketCreator", fields: [createdBy], references: [id])
  assignedTo  String?   @map("assigned_to")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  comments TicketComment[]

  @@index([status])
  @@index([type])
  @@index([createdBy])
  @@map("tickets")
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation("TicketCommenter", fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ticket_comments")
}

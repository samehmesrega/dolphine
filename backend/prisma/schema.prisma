// =============================================================
// Dolphin Platform - Unified Prisma Schema
// Single schema, single client, table prefixes for logical grouping
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// AUTH: المستخدمون والأدوار والموديولات
// =============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String
  phone         String?
  isActive      Boolean   @default(true) @map("is_active")
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  roleId        String    @map("role_id")
  role          Role      @relation(fields: [roleId], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  whatsappNumber String?  @map("whatsapp_number")

  // Relations - Leads module
  assignedLeads      Lead[]            @relation("AssignedLeads")
  communications     Communication[]
  responseRequests   ResponseRequest[] @relation("RequestedFrom")
  callbacksRequested ResponseRequest[] @relation("RequestedBy")
  tasks              Task[]            @relation("AssignedTasks")

  // Relations - Auth
  userPermissions    UserPermission[]
  auditLogs          AuditLog[]
  shiftMembers       ShiftMember[]
  notifications      Notification[]
  moduleAccess       ModuleAccess[]

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  description     String?
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  slug            String           @unique
  module          String
  description     String?
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       String     @map("user_id")
  permissionId String     @map("permission_id")
  grant        Boolean    @default(true)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

// --- Platform Modules ---

model Module {
  id          String         @id @default(uuid())
  name        String         // "Dolphin Leads", "Dolphin Marketing"
  slug        String         @unique // "leads", "marketing"
  icon        String?        // emoji or icon name
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  order       Int            @default(0)
  roles       ModuleRole[]
  access      ModuleAccess[]

  @@map("platform_modules")
}

model ModuleRole {
  id          String         @id @default(uuid())
  moduleId    String         @map("module_id")
  module      Module         @relation(fields: [moduleId], references: [id])
  name        String         // "Sales Manager"
  slug        String         // "sales_manager"
  permissions Json           // ["leads.view", "leads.create", ...]
  isDefault   Boolean        @default(false) @map("is_default")
  access      ModuleAccess[]

  @@unique([moduleId, slug])
  @@map("platform_module_roles")
}

model ModuleAccess {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String     @map("module_id")
  module       Module     @relation(fields: [moduleId], references: [id])
  moduleRoleId String     @map("module_role_id")
  moduleRole   ModuleRole @relation(fields: [moduleRoleId], references: [id])
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, moduleId])
  @@map("platform_module_access")
}

// =============================================================
// LEADS: الليدز والعملاء والطلبات
// =============================================================

model Customer {
  id           String   @id @default(uuid())
  number       Int      @default(autoincrement()) @unique
  name         String
  phone        String   @unique
  whatsapp     String?
  email        String?
  address      String?
  customFields Json?    @map("custom_fields")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  leads  Lead[]
  orders Order[]

  @@map("customers")
}

model Lead {
  id                  String     @id @default(uuid())
  number              Int        @default(autoincrement()) @unique
  name                String
  phone               String
  phoneNormalized     String     @map("phone_normalized")
  whatsapp            String?
  email               String?
  address             String?
  customFields        Json?      @map("custom_fields")
  source              String
  sourceDetail        String?    @map("source_detail")
  statusId            String     @map("status_id")
  status              LeadStatus @relation(fields: [statusId], references: [id])
  assignedToId        String?    @map("assigned_to_id")
  assignedTo          User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  customerId          String?    @map("customer_id")
  customer            Customer?  @relation(fields: [customerId], references: [id])
  lastStatusChangedAt DateTime?  @map("last_status_changed_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  // Marketing integration fields (Phase 9)
  campaignId    String? @map("campaign_id")
  creativeCode  String? @map("creative_code")
  landingPageId String? @map("landing_page_id")
  utmSource     String? @map("utm_source")
  utmMedium     String? @map("utm_medium")
  utmCampaign   String? @map("utm_campaign")
  utmContent    String? @map("utm_content")

  communications   Communication[]
  responseRequests ResponseRequest[]
  orders           Order[]
  productInterests ProductInterest[]
  tasks            Task[]

  @@index([phoneNormalized])
  @@index([statusId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([creativeCode])
  @@map("leads")
}

model LeadStatus {
  id       String   @id @default(uuid())
  name     String
  slug     String   @unique
  color    String?
  orderNum Int      @default(0) @map("order_num")
  isActive Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  leads Lead[]

  @@map("lead_statuses")
}

model ProductInterest {
  id           String   @id @default(uuid())
  leadId       String   @map("lead_id")
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  productId    String?  @map("product_id")
  product      Product? @relation(fields: [productId], references: [id])
  variation    Json?
  customFields Json?    @map("custom_fields")
  quantity     Int      @default(1)
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("product_interests")
}

model Communication {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  type      String
  notes     String?
  statusId  String?  @map("status_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@index([createdAt])
  @@map("communications")
}

model ResponseRequest {
  id              String    @id @default(uuid())
  leadId          String    @map("lead_id")
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  requestedFromId String    @map("requested_from_id")
  requestedFrom   User      @relation("RequestedFrom", fields: [requestedFromId], references: [id])
  communicationId String?   @map("communication_id")
  requestedById   String?   @map("requested_by_id")
  requestedBy     User?     @relation("RequestedBy", fields: [requestedById], references: [id])
  note            String?
  response        String?
  respondedAt     DateTime? @map("responded_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([requestedFromId])
  @@map("response_requests")
}

model LeadSource {
  id           String   @id @default(uuid())
  name         String
  type         String
  config       Json
  fieldMapping Json?    @map("field_mapping")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("lead_sources")
}

model Shift {
  id         String   @id @default(uuid())
  name       String
  startTime  String   @map("start_time")
  endTime    String   @map("end_time")
  daysOfWeek Json     @map("days_of_week")
  roundRobin Boolean  @default(false) @map("round_robin")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  shiftMembers ShiftMember[]

  @@map("shifts")
}

model ShiftMember {
  id        String   @id @default(uuid())
  shiftId   String   @map("shift_id")
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int      @default(0) @map("day_of_week")
  orderNum  Int      @default(0) @map("order_num")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([shiftId, userId, dayOfWeek])
  @@map("shift_members")
}

model Product {
  id            String   @id @default(uuid())
  wooCommerceId Int      @unique @map("woo_commerce_id")
  name          String
  slug          String?
  data          Json
  variations    Json?
  isActive      Boolean  @default(true) @map("is_active")
  syncedAt      DateTime @default(now()) @map("synced_at")

  productInterests ProductInterest[]
  orderItems       OrderItem[]
  formConnections  FormConnection[]
  sheetConnections SheetConnection[]

  @@map("products")
}

model Order {
  id                  String    @id @default(uuid())
  number              Int       @default(autoincrement()) @unique
  leadId              String    @map("lead_id")
  lead                Lead      @relation(fields: [leadId], references: [id])
  customerId          String    @map("customer_id")
  customer            Customer  @relation(fields: [customerId], references: [id])
  wooCommerceId       Int?      @unique @map("woo_commerce_id")
  status              String
  paymentType         String    @map("payment_type")
  transferImage       String?   @map("transfer_image")
  shippingName        String    @map("shipping_name")
  shippingPhone       String    @map("shipping_phone")
  shippingGovernorate String?   @map("shipping_governorate")
  shippingCity        String?   @map("shipping_city")
  shippingAddress     String?   @map("shipping_address")
  notes               String?
  accountsConfirmed   Boolean   @default(false) @map("accounts_confirmed")
  accountsConfirmedAt DateTime? @map("accounts_confirmed_at")
  accountsConfirmedBy String?   @map("accounts_confirmed_by")
  rejectedReason      String?   @map("rejected_reason")
  discount            Float?    @default(0) @map("discount")
  discountReason      String?   @map("discount_reason")
  partialAmount       Float?    @default(0) @map("partial_amount")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  orderItems OrderItem[]
  tasks      Task[]

  @@index([status])
  @@index([leadId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id])
  productName String?  @map("product_name")
  variation   Json?
  quantity    Int      @default(1)
  price       Float
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("order_items")
}

model IntegrationSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("integration_settings")
}

model SheetConnection {
  id            String   @id @default(uuid())
  name          String
  spreadsheetId String   @map("spreadsheet_id")
  sheetName     String   @default("Sheet1") @map("sheet_name")
  token         String   @unique
  fieldMapping  Json?    @map("field_mapping")
  productId     String?  @map("product_id")
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  lastSyncedRow Int      @default(0) @map("last_synced_row")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("sheet_connections")
}

model FormConnection {
  id           String   @id @default(uuid())
  name         String
  shortcode    String?  @map("shortcode")
  token        String   @unique
  fieldMapping Json?    @map("field_mapping")
  productId    String?  @map("product_id")
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("form_connections")
}

model CustomFieldConfig {
  id       String   @id @default(uuid())
  entity   String
  name     String
  slug     String
  orderNum Int      @default(0) @map("order_num")
  isActive Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([entity, slug])
  @@map("custom_field_configs")
}

// =============================================================
// PLATFORM: التدقيق والإشعارات والتاسكات
// =============================================================

model AuditLog {
  id       String   @id @default(uuid())
  userId   String?  @map("user_id")
  user     User?    @relation(fields: [userId], references: [id])
  action   String
  entity   String
  entityId String   @map("entity_id")
  oldData  Json?    @map("old_data")
  newData  Json?    @map("new_data")
  ip       String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id       String    @id @default(uuid())
  userId   String    @map("user_id")
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  body     String?
  type     String
  entity   String?
  entityId String?   @map("entity_id")
  link     String?
  isRead   Boolean   @default(false) @map("is_read")
  readAt   DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Task {
  id           String    @id @default(uuid())
  type         String
  title        String
  description  String?
  status       String    @default("pending")
  assignedToId String    @map("assigned_to_id")
  assignedTo   User      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  leadId       String?   @map("lead_id")
  lead         Lead?     @relation(fields: [leadId], references: [id])
  orderId      String?   @map("order_id")
  order        Order?    @relation(fields: [orderId], references: [id])
  ruleId       String?   @map("rule_id")
  rule         TaskRule? @relation(fields: [ruleId], references: [id])
  snoozedUntil DateTime? @map("snoozed_until")
  completedAt  DateTime? @map("completed_at")
  completedById String?  @map("completed_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([assignedToId])
  @@index([status])
  @@index([leadId])
  @@map("tasks")
}

model TaskRule {
  id         String   @id @default(uuid())
  action     String
  statusSlug String   @map("status_slug")
  afterHours Int      @map("after_hours")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@map("task_rules")
}

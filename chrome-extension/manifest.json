{
  "manifest_version": 3,
  "name": "Dolphin WhatsApp Monitor",
  "version": "1.0.0",
  "description": "Monitor WhatsApp Web chats for Dolphin CRM — auto-capture conversations linked to leads",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["content/dom-selectors.js", "content/phone-extractor.js", "content/whatsapp-monitor.js"],
    "run_at": "document_idle"
  }],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": { "48": "icons/icon48.png" }
  },
  "icons": { "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
